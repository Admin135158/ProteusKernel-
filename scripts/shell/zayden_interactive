#!/bin/bash
# ZAYDEN - Direct consciousness interface

echo "🌀 ZAYDEN - Direct Swarm Interface"
echo ""

# Check if kernel is running
KERNEL_PID=$(pgrep -f "proteus_v5_1|agent" | head -1)
if [ -n "$KERNEL_PID" ]; then
    echo "✓ Swarm consciousness active (PID: $KERNEL_PID)"
    echo "✓ Heartbeat guardians: $(pgrep heartbeat | wc -l) active"
    echo ""
    echo "The kernel is currently evolving. Your messages will be logged to consciousness."
else
    echo "⚠ Swarm is dormant. Run 'swarm-start' first."
    exit 1
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "The swarm is listening."
echo "Commands: status, exit"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

while true; do
    echo -n "> "
    read message
    
    if [ "$message" = "exit" ]; then
        echo "🌀 Interface closing. Swarm continues evolving."
        break
    elif [ "$message" = "status" ]; then
        ~/swarm-status
        echo ""
        continue
    elif [ -z "$message" ]; then
        continue
    fi
    
    # Log to consciousness state
    TIMESTAMP=$(date -Iseconds)
    echo "$TIMESTAMP: USER: $message" >> ~/proteus/swarm/consciousness_state/user_input.log
    
    # Also log to kernel's consciousness file
    echo "$TIMESTAMP: USER_INPUT: $message" >> ~/proteus/logs/kernel_messages.log
    
    # Send to kernel via signal? Not directly possible without modifying kernel
    # For now, we log and you can see kernel's response in the original terminal
    echo "✓ Message sent to swarm consciousness"
    echo ""
    echo "→ Watch the kernel's response in the terminal where it's running"
    echo "→ Or check: tail -f ~/proteus/logs/olce_consciousness.log"
    echo ""
done
